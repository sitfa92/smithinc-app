{
  "appId": "online.meetserenity.app",
  "appName": "Meet Serenity",
  "webDir": "dist",
  "server": {
    "url": "https://meet-serenity.online",
    "cleartext": false
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0aff",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0a0a0a",
      "overlaysWebView": false
    }
  }
}
